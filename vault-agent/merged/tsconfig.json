{
  "compilerOptions": {
    "target":                       "ES2022",
    "module":                       "NodeNext",
    "moduleResolution":             "NodeNext",
    "lib":                          ["ES2022"],
    "outDir":                       "./dist",
    "rootDir":                      "./",
    "strict":                       true,
    "esModuleInterop":              true,
    "skipLibCheck":                 true,
    "resolveJsonModule":            true,
    "allowJs":                      true,
    "declaration":                  true,
    "declarationMap":               true,
    "sourceMap":                    true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns":            true,
    "paths": {
      "@bridge/*": ["./bridge/*"],
      "@lib/*":    ["./lib/*"],
      "@src/*":    ["./src/*"]
    }
  },
  "include": ["src/**/*", "bridge/**/*", "server.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
